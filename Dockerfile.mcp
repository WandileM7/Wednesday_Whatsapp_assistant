# ============================================
# MCP Server - Lightweight Dockerfile
# ============================================
# Optimized container for the MCP server only.
# Smaller image, faster startup, lower resource usage.

FROM python:3.12-slim-bookworm AS base

WORKDIR /app

# Install minimal system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN groupadd -r wednesday && useradd -r -g wednesday wednesday

# Copy requirements first for cache optimization
COPY requirements.txt .

# Install Python dependencies (minimal for MCP HTTP server)
RUN pip install --no-cache-dir \
    mcp \
    flask \
    python-dotenv \
    requests \
    bytez \
    spotipy \
    google-api-python-client \
    google-auth \
    google-auth-oauthlib

# Copy only MCP server code and necessary modules
COPY mcp_server/ /app/mcp_server/
COPY handlers/ /app/handlers/
COPY database.py /app/
COPY config.py /app/
COPY helpers/ /app/helpers/

# Create necessary directories
RUN mkdir -p /app/session /app/task_data /app/flask_session && \
    chown -R wednesday:wednesday /app

# Switch to non-root user
USER wednesday

# Environment variables
ENV PATH=/home/wednesday/.local/bin:$PATH
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app
ENV MCP_PORT=8080
ENV MCP_HOST=0.0.0.0

# Expose MCP HTTP port (for SSE transport)
EXPOSE 8080

# Health check for Kubernetes
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

# Run MCP HTTP server (for Kubernetes deployment)
CMD ["python", "-m", "mcp_server.http_server"]
