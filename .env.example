# Wednesday WhatsApp Assistant - Environment Configuration
# Copy to .env and fill in values (only needed for local dev without Docker)

# n8n relay settings
N8N_WEBHOOK_URL=http://n8n:5678
N8N_WEBHOOK_PATH=/webhook/whatsapp-webhook
N8N_TIMEOUT=120

# WhatsApp service
WAHA_URL=http://whatsapp-service:3000/api/sendText

# Flask
FLASK_DEBUG=false
FLASK_SECRET_KEY=change-me-to-a-random-string

# Rate limiting
RATE_LIMIT=30

# n8n dashboard credentials (used in docker-compose)
N8N_USER=admin
N8N_PASSWORD=wednesday123
N8N_ENCRYPTION_KEY=change-me-to-at-least-32-characters!!

# OpenAI key (passed to n8n container)
OPENAI_API_KEY=sk-your-openai-key-here
